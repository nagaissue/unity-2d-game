# Ignore everything by default
*

# Re-include only the files and folders that should be tracked
!.gitignore
!README.md
!Assets/
!Assets/**
!Packages/
!Packages/**
!ProjectSettings/
!ProjectSettings/**

# Unity generated folders
/Library/
/Temp/
/Obj/
/Build/
/Builds/
/Logs/
/UserSettings/

# IDE / OS files
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
